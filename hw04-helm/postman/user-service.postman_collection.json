{
  "info": {
    "name": "OTUS user-service CRUD",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://arch.homework"
    }
  ],
  "item": [
    {
      "name": "Create user",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/user",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"johndoe\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"+79990001122\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () { pm.response.to.have.status(200); });",
              "var user = pm.response.json();",
              "pm.test('user has id', function () { pm.expect(user.id).to.be.a('number'); });",
              "pm.test('username saved', function () { pm.expect(user.username).to.eql('johndoe'); });",
              "pm.collectionVariables.set('userId', user.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Get user",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/user/{{userId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () { pm.response.to.have.status(200); });",
              "var user = pm.response.json();",
              "pm.test('username matches', function () { pm.expect(user.username).to.eql('johndoe'); });",
              "pm.test('firstName matches', function () { pm.expect(user.firstName).to.eql('John'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Update user",
      "request": {
        "method": "PUT",
        "url": "{{baseUrl}}/user/{{userId}}",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"johndoe\",\n  \"firstName\": \"Johnny\",\n  \"lastName\": \"Doe\",\n  \"email\": \"johnny@example.com\",\n  \"phone\": \"+79990001122\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () { pm.response.to.have.status(200); });",
              "var user = pm.response.json();",
              "pm.test('firstName updated', function () { pm.expect(user.firstName).to.eql('Johnny'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Get user after update",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/user/{{userId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', function () { pm.response.to.have.status(200); });",
              "var user = pm.response.json();",
              "pm.test('firstName is updated in db', function () { pm.expect(user.firstName).to.eql('Johnny'); });",
              "pm.test('email is updated in db', function () { pm.expect(user.email).to.eql('johnny@example.com'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Delete user",
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/user/{{userId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 204', function () { pm.response.to.have.status(204); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Get deleted user",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/user/{{userId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 404', function () { pm.response.to.have.status(404); });",
              "pm.test('error message', function () { pm.expect(pm.response.json().error).to.eql('user not found'); });"
            ]
          }
        }
      ]
    }
  ]
}
